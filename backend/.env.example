# ─────────────────────────────────────────────────────────────
# HiVoid Hub — Backend Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────

PROJECT_NAME="HiVoid Subscription Hub"

# Master token that edge nodes must send to authenticate
HUB_MASTER_TOKEN=change-this-to-a-random-secret

# JWT signing secret for admin panel sessions
SECRET_KEY=change-this-to-a-long-random-string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis for real-time traffic quota tracking
REDIS_URL=redis://localhost:6379/0

# PostgreSQL connection string
SQLALCHEMY_DATABASE_URI=postgresql://postgres:postgres@localhost:5432/hivoid_hub
